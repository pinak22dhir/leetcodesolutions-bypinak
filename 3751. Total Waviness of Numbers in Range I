class Solution {
    public int totalWaviness(int num1, int num2) {
        int s=0;
        for(int i=num1;i<=num2;i++){
             s+=waviness(i);
        }
        return s;
    }
    static int waviness(int number){
        ArrayList<Integer>li=new ArrayList<>();
        int t=10;
        while(number>0){
            int lastdigit=number%10;
            number=number/10;
            li.add(lastdigit);
        }
        if(li.size()==2){
                return 0;
        }
        int s=0;
        for(int i=1;i<li.size()-1;i++){
             if((li.get(i)>li.get(i-1) && li.get(i)>li.get(i+1))||
            (li.get(i)<li.get(i-1) && li.get(i)<li.get(i+1))){
                 s+=1;
        }
        }
         return s;
    }
}
