class Solution {
    public long maximumHappinessSum(int[] happiness, int k) {
        Arrays.sort(happiness);
        long s=0;
        int minus=-1;
        for(int i=happiness.length-1;i>=happiness.length-k;i--){
            if(i==happiness.length-1){
            s+=happiness[i];
            }
            else{
              long si=happiness[i]+minus;
             if(si>0){
                s+=si;
             }
             minus=minus-1;
            }
        }
      return s;
    }
}
